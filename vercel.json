{
  "functions": {
    "public/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/(.*\\.php)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/public/index.php"
    }
  ]
}